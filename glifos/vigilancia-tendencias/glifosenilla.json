{
  "id": "vigilancia-tendencias",
  "nombre": "Vigilancia de Tendencias",
  "tipo": "sistema",
  "descripcion": "Monitoreo diario de Google Trends, generacion de reportes y alimentacion del nucleo BDGB",
  "estado": "activo",
  "version": "1.0",
  "creado": "2026-06-08",

  "glifos": [
    {
      "id": "primo",
      "nombre": "Glifo Primo",
      "tipo": "nativo",
      "entry": "bdgb --glifo-run primo",
      "descripcion": "Fetch via RSS, reporte .txt, inyeccion en BDGB"
    },
    {
      "id": "trend-tracker",
      "nombre": "Trend Tracker Diario",
      "tipo": "externo",
      "entry": "python3 glifos/vigilancia-tendencias/glifos/trend-tracker/trend_tracker.py",
      "lenguaje": "python3",
      "descripcion": "Google Trends + pytrends, reporte JSON/PDF, resumen semanal"
    }
  ],

  "relaciones": [
    {
      "de": "primo",
      "a": "trend-tracker",
      "tipo": "ejecucion",
      "flujo": "primo debe ejecutarse antes que trend-tracker, su reporte .txt es insumo opcional"
    }
  ],

  "pipeline": [
    {
      "orden": 1,
      "glifo": "primo",
      "accion": "fetch + report + inject",
      "args": [],
      "descripcion": "Obtener tendencias via RSS, guardar reporte .txt, inyectar conceptos en BDGB"
    },
    {
      "orden": 2,
      "glifo": "trend-tracker",
      "accion": "--daily",
      "args": ["--daily"],
      "dependencias": ["primo"],
      "descripcion": "Reporte JSON + PDF con pytrends, inyeccion adicional en BDGB"
    },
    {
      "orden": 3,
      "glifo": "trend-tracker",
      "accion": "--weekly",
      "args": ["--weekly"],
      "condicion": "cada 7 dias",
      "dependencias": ["primo"],
      "descripcion": "Acumular 7 reportes diarios y generar resumen semanal"
    }
  ],

  "datos_sistema": {
    "fuentes": ["google-trends-rss", "pytrends-api"],
    "palabras_clave": ["inteligencia artificial", "pixel art", "video juegos", "musica", "ia"],
    "horario_ejecucion": "08:00 Mexico City",
    "formatos_reporte": [".txt", ".json", ".pdf"],
    "max_tendencias_por_dia": 10,
    "dias_para_resumen_semanal": 7,
    "inyectar_en_bdgb": true
  },

  "metricas": {
    "ejecuciones": 0,
    "exitosas": 0,
    "fallidas": 0,
    "ultima_ejecucion": null,
    "dias_consecutivos": 0
  }
}
