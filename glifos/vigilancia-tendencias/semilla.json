{
  "id": "vigilancia-tendencias",
  "nombre": "Vigilancia de Tendencias",
  "tipo": "panal",
  "descripcion": "Monitoreo diario de Google Trends, generacion de reportes y alimentacion del nucleo BDGB",
  "estado": "activo",
  "version": "1.0",
  "rama": "online",
  "creado": "2026-06-08",

  "_regla": "Esta semilla es la autoridad del panal. Lo que no esta declarado aqui no existe ni se ejecuta.",
  "_clasificacion": "Primo=codigo original (src/glifo.c). Semilla=este archivo. Comun=glifos operativos.",

  "tiempo": {
    "tipo": "autonomo",
    "modalidad": "repetitivo",
    "descripcion": "Se activa diario a las 08:00 Mexico City. Repite hasta que se desactive manualmente",
    "schedule": {
      "tipo": "diario",
      "hora": "08:00",
      "zona_horaria": "America/Mexico_City"
    },
    "fin": {
      "tipo": "indefinido",
      "comentario": "Sigue funcionando hasta decision manual del operador"
    }
  },

  "config": {
    "pipeline": ["primo", "trend-tracker"]
  },

  "glifos": [
    {
      "id": "primo",
      "nombre": "Glifo Primo",
      "tipo": "nativo",
      "entry": "bdgb --glifo-run primo",
      "actualizable": false,
      "descripcion": "Fetch via RSS, reporte .txt, inyeccion en BDGB",
      "inputs": [],
      "outputs": ["pipeline_state/tendencias.json", "pipeline_state/reporte_primo.txt"],
      "glifo_json": "glifos/primo/glifo.json"
    },
    {
      "id": "trend-tracker",
      "nombre": "Trend Tracker Diario",
      "tipo": "externo",
      "entry": "python3 glifos/vigilancia-tendencias/glifos/trend-tracker/trend_tracker.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Google Trends + pytrends, reporte JSON/PDF, resumen semanal",
      "inputs": ["pipeline_state/tendencias.json"],
      "outputs": ["pipeline_state/reporte_tracker.json", "pipeline_state/resumen_semanal.json"],
      "glifo_json": "glifos/trend-tracker/glifo.json"
    }
  ],

  "relaciones": [
    {
      "de": "primo",
      "a": "trend-tracker",
      "tipo": "ejecucion",
      "flujo": "primo debe ejecutarse antes que trend-tracker, su reporte .txt es insumo opcional"
    }
  ],

  "pipeline": {
    "orden": [
      {
        "paso": 1,
        "glifo": "primo",
        "accion": "fetch + report + inject",
        "args": [],
        "descripcion": "Obtener tendencias via RSS, guardar reporte .txt, inyectar conceptos en BDGB"
      },
      {
        "paso": 2,
        "glifo": "trend-tracker",
        "accion": "--daily",
        "args": ["--daily"],
        "dependencias": ["primo"],
        "descripcion": "Reporte JSON + PDF con pytrends, inyeccion adicional en BDGB"
      },
      {
        "paso": 3,
        "glifo": "trend-tracker",
        "accion": "--weekly",
        "args": ["--weekly"],
        "condicion": "cada 7 dias",
        "dependencias": ["primo"],
        "descripcion": "Acumular 7 reportes diarios y generar resumen semanal"
      }
    ]
  },

  "datos_panal": {
    "fuentes": ["google-trends-rss", "pytrends-api"],
    "palabras_clave": ["inteligencia artificial", "pixel art", "video juegos", "musica", "ia"],
    "horario_ejecucion": "08:00 Mexico City",
    "formatos_reporte": [".txt", ".json", ".pdf"],
    "max_tendencias_por_dia": 10,
    "dias_para_resumen_semanal": 7,
    "inyectar_en_bdgb": true
  },

  "metricas": {
    "ejecuciones": 0,
    "exitosas": 0,
    "fallidas": 0,
    "ultima_ejecucion": null,
    "dias_consecutivos": 0
  }
}
