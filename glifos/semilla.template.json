{
  "id": "nombre-del-panal-o-colmena",
  "nombre": "Nombre Humano",
  "tipo": "panal | colmena",
  "descripcion": "Describir que flujo de trabajo realiza",
  "estado": "activo",
  "version": "1.0",
  "rama": "online / local / hibrida",
  "creado": "YYYY-MM-DD",

  "_regla": "Esta semilla es la autoridad. Lo que no esta declarado aqui no existe ni se ejecuta.",
  "_clasificacion": "Primo=codigo original (src/glifo.c). Semilla=este archivo. Comun=glifos operativos.",
  "_nota_tipo": "Si tipo=colmena, solo contiene panales como glifos. No tiene tools directas.",

  "tiempo": {
    "tipo": "autonomo | dirigido",
    "modalidad": "repetitivo | encargo | autonomo",
    "descripcion": "repetitivo=programado con horario, repite hasta fin. encargo=una vez, lo pide el usuario. autonomo=sin intervencion",
    "inicio": {
      "trigger": "manual | schedule | dependencia",
      "via": "comando / horario / archivo senal"
    },
    "fin": {
      "tipo": "duracion | senal | cleanup | indefinido",
      "descripcion": "Cuando y como termina el ciclo de vida del panal"
    }
  },

  "config": {
    "pipeline": ["glifo-1", "glifo-externo", "cleanup"]
  },

  "glifos": [
    {
      "id": "glifo-1",
      "nombre": "Nombre del Glifo",
      "tipo": "nativo",
      "entry": "bdgb --glifo-run glifo-1",
      "actualizable": false,
      "glifo_principal": true,
      "descripcion": "Que hace este glifo",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/glifo-1/glifo.json",
      "tiempo": {
        "modalidad": "dirigido",
        "inicio": {"trigger": "manual", "via": "bdgb --glifo-run glifo-1"},
        "fin": {"tipo": "senal", "descripcion": "Termina y deja datos en pipeline_state"}
      },
      "bibliotecario": {
        "recursos": [],
        "credenciales": {},
        "permisos": []
      }
    },
    {
      "id": "glifo-externo",
      "nombre": "Glifo Externo",
      "tipo": "externo",
      "entry": "python3 glifos/<panal>/glifos/glifo-externo/script.py",
      "lenguaje": "python3",
      "actualizable": true,
      "glifo_principal": false,
      "descripcion": "Glifo externo actualizable",
      "inputs": ["pipeline_state/datos.json"],
      "outputs": ["pipeline_state/resultado.txt"],
      "glifo_json": "glifos/glifo-externo/glifo.json",
      "tiempo": {
        "modalidad": "dirigido",
        "inicio": {"trigger": "dependencia", "via": "pipeline_state/datos.json"},
        "fin": {"tipo": "senal", "descripcion": "Escribe pipeline_state/resultado.txt"}
      },
      "bibliotecario": {
        "recursos": ["prompts/template.md"],
        "credenciales": {
          "api_x": {"tipo": "env", "key": "API_X_KEY"}
        },
        "permisos": ["read:pipeline_state", "write:pipeline_state"]
      }
    },
    {
      "id": "sub-panal",
      "nombre": "Panal Integrado",
      "tipo": "panal",
      "ref": "glifos/sub-panal/semilla.json",
      "actualizable": false,
      "glifo_principal": false,
      "descripcion": "Panal completo que funciona como glifo dentro de este panal o colmena",
      "inputs": [],
      "outputs": []
    }
  ],

  "relaciones": [
    {
      "de": "glifo-1",
      "a": "glifo-externo",
      "tipo": "ejecucion",
      "flujo": "glifo-1 ejecuta antes que glifo-externo"
    }
  ],

  "pipeline": {
    "orden": [
      {
        "paso": 1,
        "glifo": "glifo-1",
        "accion": "accion por defecto",
        "args": [],
        "descripcion": "Que hace en este paso"
      },
      {
        "paso": 2,
        "glifo": "glifo-externo",
        "accion": "--run",
        "args": ["--run"],
        "dependencias": ["glifo-1"],
        "descripcion": "Que hace en este paso"
      }
    ]
  },

  "datos_panal": {
    "nota": "Completamente personalizable segun la tarea",
    "ejemplo_clave": "valor",
    "ia_modo": "navegador | api | mock",
    "ia_nota": "navegador=la IA se usa como usuario humano a traves del browser. api=llamada directa. mock=simulado"
  },

  "metricas": {
    "ejecuciones": 0,
    "exitosas": 0,
    "fallidas": 0,
    "ultima_ejecucion": null
  }
}
