{
  "id": "generacion-contenido",
  "nombre": "Generacion de Contenido desde Tendencias",
  "tipo": "panal",
  "descripcion": "Pipeline completo: tendencias → articulo IA via PyAutoGUI → PDF en escritorio → extraer guion → video NotebookLM → publicar en YouTube canal glifos",
  "estado": "activo",
  "version": "2.0",
  "rama": "online",
  "creado": "2026-06-09",

  "_regla": "Esta semilla es la autoridad del panal. Lo que no esta declarado aqui no existe ni se ejecuta.",
  "_clasificacion": "Primo=codigo original (src/glifo.c). Semilla=este archivo. Comun=glifos operativos.",
  "_protocolo": "Los glifos se comunican mediante archivos JSON en pipeline_state/. Cada glifo lee sus inputs de ahi y escribe sus outputs ahi.",

  "tiempo": {
    "tipo": "dirigido",
    "modalidad": "encargo",
    "descripcion": "Se ejecuta a solicitud del usuario. Cada vez que se invoca bdgb --glifo-run generacion-contenido, recorre el pipeline completo una vez y termina"
  },

  "config": {
    "pipeline": ["estrutura", "trend-fetcher", "authority-selector", "content-writer", "clipboard-capturer", "guion-loader", "notebook-abrir", "notebook-vision", "notebook-cuaderno", "notebook-guion", "notebook-video", "notebook-descargar", "notebook-cerrar", "youtube-subir", "cleanup"]
  },

  "glifos": [
    {
      "id": "estrutura",
      "nombre": "Verificador de Estructura",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/estrutura/estrutura.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Verifica que todos los directorios, archivos y recursos necesarios existen. Crea los que faltan.",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/estrutura/glifo.json"
    },
    {
      "id": "trend-fetcher",
      "nombre": "Buscador de Tendencias",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/trend-fetcher/trend_fetcher.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Obtiene tendencias de internet (Google Trends RSS + pytrends)",
      "inputs": [],
      "outputs": ["pipeline_state/tendencias.json"],
      "glifo_json": "glifos/trend-fetcher/glifo.json"
    },
    {
      "id": "authority-selector",
      "nombre": "Selector por Autoridad",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/authority-selector/selector.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Recibe las tendencias y elige la de mayor autoridad (score + volumen)",
      "inputs": ["pipeline_state/tendencias.json"],
      "outputs": ["pipeline_state/tema_seleccionado.json"],
      "glifo_json": "glifos/authority-selector/glifo.json"
    },
    {
      "id": "content-writer",
      "nombre": "Redactor de Articulos IA",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/content-writer/writer.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Abre ChatGPT en navegador via PyAutoGUI, escribe prompt y extrae respuesta",
      "inputs": ["pipeline_state/tema_seleccionado.json"],
      "outputs": ["pipeline_state/respuesta_ia.txt"],
      "glifo_json": "glifos/content-writer/glifo.json"
    },
    {
      "id": "clipboard-capturer",
      "nombre": "Capturador de Portapapeles",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/clipboard-capturer/capturer.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Lee respuesta_ia.txt y genera PDF en Desktop/guiones/",
      "inputs": ["pipeline_state/respuesta_ia.txt"],
      "outputs": ["Desktop/guiones/*.pdf"],
      "glifo_json": "glifos/clipboard-capturer/glifo.json"
    },
    {
      "id": "guion-loader",
      "nombre": "Cargador de Guion desde PDF",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/guion-loader/guion_loader.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Busca PDF mas reciente en ~/Desktop/guiones/, extrae texto a pipeline_state/guion.txt",
      "inputs": [],
      "outputs": ["pipeline_state/guion.txt", "pipeline_state/guion_meta.json"],
      "glifo_json": "glifos/guion-loader/glifo.json"
    },
    {
      "id": "notebook-abrir",
      "nombre": "Abrir NotebookLM",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-abrir/abrir.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Lanza NotebookLM PWA desde acceso directo, hace login si es necesario",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/notebook-abrir/glifo.json"
    },
    {
      "id": "notebook-vision",
      "nombre": "Vision de Pantalla",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-vision/vision.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Escanea pantalla, detecta botones por color, guarda coordenadas en pipeline_state/vista.json",
      "inputs": [],
      "outputs": ["pipeline_state/vista.json"],
      "glifo_json": "glifos/notebook-vision/glifo.json"
    },
    {
      "id": "notebook-cuaderno",
      "nombre": "Crear Cuaderno",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-cuaderno/cuaderno.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Hace click en Crear nuevo cuaderno via PyAutoGUI (posicion calibrada)",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/notebook-cuaderno/glifo.json"
    },
    {
      "id": "notebook-guion",
      "nombre": "Subir PDF a Cuaderno",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-guion/guion.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Sube PDF al cuaderno via PyAutoGUI (click + dialogo nativo)",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/notebook-guion/glifo.json"
    },
    {
      "id": "notebook-video",
      "nombre": "Generar Video en NotebookLM",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-video/video.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Hace click en Studio + Crear video via PyAutoGUI (posiciones calibradas)",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/notebook-video/glifo.json"
    },
    {
      "id": "notebook-descargar",
      "nombre": "Descargar Video",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-descargar/descargar.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Espera que el usuario descargue el video a ~/Desktop/videos/ y lo copia a pipeline_state",
      "inputs": [],
      "outputs": ["pipeline_state/video.mp4"],
      "glifo_json": "glifos/notebook-descargar/glifo.json"
    },
    {
      "id": "notebook-cerrar",
      "nombre": "Cerrar Cuaderno",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/notebook-cerrar/cerrar.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Elimina cuaderno via PyAutoGUI (menu opciones + eliminar + confirmar)",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/notebook-cerrar/glifo.json"
    },
    {
      "id": "youtube-subir",
      "nombre": "Subir Video a YouTube",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/youtube-subir/subir.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Abre YouTube Studio, guia al usuario para subir el video al canal glifos",
      "inputs": ["pipeline_state/video.mp4"],
      "outputs": ["pipeline_state/publicado.json"],
      "glifo_json": "glifos/youtube-subir/glifo.json"
    },
    {
      "id": "cleanup",
      "nombre": "Limpiador de Recursos",
      "tipo": "externo",
      "entry": "python glifos/generacion-contenido/glifos/cleanup/cleaner.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Limpia temporales. No mata procesos del usuario.",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/cleanup/glifo.json"
    }
  ],

  "relaciones": [
    {
      "de": "trend-fetcher",
      "a": "authority-selector",
      "tipo": "datos",
      "flujo": "trend-fetcher escribe pipeline_state/tendencias.json, authority-selector lo lee",
      "protocolo": "pipeline_state/tendencias.json"
    },
    {
      "de": "authority-selector",
      "a": "content-writer",
      "tipo": "datos",
      "flujo": "authority-selector escribe pipeline_state/tema_seleccionado.json, content-writer lo lee",
      "protocolo": "pipeline_state/tema_seleccionado.json"
    },
    {
      "de": "content-writer",
      "a": "clipboard-capturer",
      "tipo": "archivo",
      "flujo": "content-writer escribe pipeline_state/respuesta_ia.txt, clipboard-capturer lo lee",
      "protocolo": "pipeline_state/respuesta_ia.txt"
    },
    {
      "de": "clipboard-capturer",
      "a": "guion-loader",
      "tipo": "archivo",
      "flujo": "clipboard-capturer genera PDF en ~/Desktop/guiones/, guion-loader lo lee y extrae texto",
      "protocolo": "~/Desktop/guiones/<ultimo>.pdf"
    },
    {
      "de": "guion-loader",
      "a": "notebook-abrir",
      "tipo": "datos",
      "flujo": "guion-loader escribe pipeline_state/guion.txt, notebook-abrir arranca NotebookLM",
      "protocolo": "pipeline_state/guion.txt"
    },
    {
      "de": "notebook-abrir",
      "a": "notebook-vision",
      "tipo": "vision",
      "flujo": "PWA abierta, vision.py escanea pantalla para detectar boton",
      "protocolo": "coordenadas en pipeline_state/vista.json"
    },
    {
      "de": "notebook-vision",
      "a": "notebook-cuaderno",
      "tipo": "datos",
      "flujo": "vision.py escribe pipeline_state/vista.json, cuaderno.py lo lee y clickea",
      "protocolo": "pipeline_state/vista.json"
    },
    {
      "de": "notebook-cuaderno",
      "a": "notebook-guion",
      "tipo": "pyautogui",
      "flujo": "Misma PWA, guion.py sube PDF via PyAutoGUI",
      "protocolo": "coordenadas calibradas + ruta PDF"
    },
    {
      "de": "notebook-guion",
      "a": "notebook-video",
      "tipo": "pyautogui",
      "flujo": "Misma PWA, video.py clickea Studio + Crear video via PyAutoGUI",
      "protocolo": "coordenadas calibradas"
    },
    {
      "de": "notebook-video",
      "a": "notebook-descargar",
      "tipo": "archivo",
      "flujo": "Usuario descarga video a ~/Desktop/videos/, descargar.py lo copia a pipeline_state",
      "protocolo": "pipeline_state/video.mp4"
    },
    {
      "de": "notebook-descargar",
      "a": "notebook-cerrar",
      "tipo": "pyautogui",
      "flujo": "Misma PWA, cerrar.py elimina cuaderno via PyAutoGUI",
      "protocolo": "coordenadas calibradas"
    },
    {
      "de": "notebook-cerrar",
      "a": "youtube-subir",
      "tipo": "archivo",
      "flujo": "youtube-subir sube pipeline_state/video.mp4 al canal glifos",
      "protocolo": "pipeline_state/video.mp4"
    },
    {
      "de": "youtube-subir",
      "a": "cleanup",
      "tipo": "cierre",
      "flujo": "cleanup limpia temporales y recursos",
      "protocolo": "ninguno"
    }
  ],

  "pipeline": {
    "orden": [
      {
        "paso": 0,
        "glifo": "estrutura",
        "accion": "verify",
        "args": [],
        "descripcion": "Verificar estructura del panal: directorios, archivos, recursos. Crear lo faltante."
      },
      {
        "paso": 1,
        "glifo": "trend-fetcher",
        "accion": "fetch",
        "args": [],
        "dependencias": ["estrutura"],
        "descripcion": "Obtener tendencias de Google Trends RSS + pytrends, guardar en pipeline_state/tendencias.json"
      },
      {
        "paso": 2,
        "glifo": "authority-selector",
        "accion": "select",
        "args": [],
        "dependencias": ["trend-fetcher"],
        "descripcion": "Leer pipeline_state/tendencias.json, seleccionar la de mayor autoridad, guardar en pipeline_state/tema_seleccionado.json"
      },
      {
        "paso": 3,
        "glifo": "content-writer",
        "accion": "pyautogui-browser",
        "args": [],
        "dependencias": ["authority-selector"],
        "descripcion": "Abrir ChatGPT en navegador via PyAutoGUI, escribir prompt, enviar, extraer respuesta a pipeline_state/respuesta_ia.txt"
      },
      {
        "paso": 4,
        "glifo": "clipboard-capturer",
        "accion": "pdf",
        "args": [],
        "dependencias": ["content-writer"],
        "descripcion": "Leer pipeline_state/respuesta_ia.txt, generar PDF en Desktop/guiones/"
      },
      {
        "paso": 5,
        "glifo": "guion-loader",
        "accion": "extract",
        "args": [],
        "dependencias": ["clipboard-capturer"],
        "descripcion": "Leer PDF mas reciente de ~/Desktop/guiones/, extraer texto a pipeline_state/guion.txt"
      },
      {
        "paso": 6,
        "glifo": "notebook-abrir",
        "accion": "pyautogui-launch",
        "args": [],
        "dependencias": ["guion-loader"],
        "descripcion": "Lanzar NotebookLM PWA desde acceso directo, autologin con PyAutoGUI"
      },
      {
        "paso": 7,
        "glifo": "notebook-vision",
        "accion": "vision-scan",
        "args": [],
        "dependencias": ["notebook-abrir"],
        "descripcion": "Escanear pantalla con PyAutoGUI, detectar botones por color, guardar coordenadas en pipeline_state/vista.json"
      },
      {
        "paso": 8,
        "glifo": "notebook-cuaderno",
        "accion": "pyautogui-click",
        "args": [],
        "dependencias": ["notebook-vision"],
        "descripcion": "Leer coordenadas de vista.json y hacer click en Crear nuevo cuaderno"
      },
      {
        "paso": 9,
        "glifo": "notebook-guion",
        "accion": "pyautogui-upload",
        "args": [],
        "dependencias": ["notebook-cuaderno"],
        "descripcion": "Click upload + escribir ruta PDF en dialogo nativo via PyAutoGUI"
      },
      {
        "paso": 10,
        "glifo": "notebook-video",
        "accion": "pyautogui-click",
        "args": [],
        "dependencias": ["notebook-guion"],
        "descripcion": "Click Studio tab + Crear video + Crear via PyAutoGUI (posiciones calibradas)"
      },
      {
        "paso": 11,
        "glifo": "notebook-descargar",
        "accion": "poll",
        "args": [],
        "dependencias": ["notebook-video"],
        "descripcion": "Esperar que usuario descargue el video a ~/Desktop/videos/, copiarlo a pipeline_state/video.mp4"
      },
      {
        "paso": 12,
        "glifo": "notebook-cerrar",
        "accion": "pyautogui-click",
        "args": [],
        "dependencias": ["notebook-descargar"],
        "descripcion": "Eliminar cuaderno via PyAutoGUI (menu opciones + eliminar + confirmar)"
      },
      {
        "paso": 13,
        "glifo": "youtube-subir",
        "accion": "semi-auto",
        "args": [],
        "dependencias": ["notebook-cerrar"],
        "descripcion": "Abrir YouTube Studio, guiar al usuario para subir el video al canal glifos y publicar"
      },
      {
        "paso": 14,
        "glifo": "cleanup",
        "accion": "clean",
        "args": [],
        "dependencias": ["youtube-subir"],
        "descripcion": "Limpiar temporales. No mata procesos."
      }
    ]
  },

  "datos_panal": {
    "protocolo_comunicacion": "pipeline_state/ — archivos JSON/txt temporales. Cada glifo lee inputs de ahi y escribe outputs.",
    "fuentes": ["google-trends-rss", "pytrends-api", "mock-internet"],
    "criterio_autoridad": "score + volumen de busqueda",
    "formato_salida": "PDF → Video MP4 → YouTube",
    "carpeta_destino_guion": "Desktop/guiones/",
    "carpeta_destino_video": "~/Desktop/videos/",
    "canal_youtube": "glifos",
    "ia_modo": "PyAutoGUI (automatizacion de UI por coordenadas/imagenes)",
    "ia_config": {
      "url_web": "https://chatgpt.com",
      "metodo": "PyAutoGUI → mouse click → teclear prompt → Enter → extraer respuesta",
      "dependencias": "pyautogui, pillow, pygetwindow (pip install)",
      "variable_entorno_sitio": "BDGB_AI_WEB_URL",
      "variable_entorno_modo": "BDGB_AI_MODE (browser | mock)",
      "calibracion": "python calibrar.py para guardar posiciones de botones"
    }
  },

  "metricas": {
    "ejecuciones": 0,
    "exitosas": 0,
    "fallidas": 0,
