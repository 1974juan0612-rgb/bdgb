{
  "id": "generacion-contenido",
  "nombre": "Generacion de Contenido desde Tendencias",
  "tipo": "panal",
  "descripcion": "Pipeline completo: tendencias → articulo IA via CDP → PDF en escritorio → extraer guion → video NotebookLM → publicar en YouTube canal glifos",
  "estado": "activo",
  "version": "2.0",
  "rama": "online",
  "creado": "2026-06-09",

  "_regla": "Esta semilla es la autoridad del panal. Lo que no esta declarado aqui no existe ni se ejecuta.",
  "_clasificacion": "Primo=codigo original (src/glifo.c). Semilla=este archivo. Comun=glifos operativos.",
  "_protocolo": "Los glifos se comunican mediante archivos JSON en pipeline_state/. Cada glifo lee sus inputs de ahi y escribe sus outputs ahi.",

  "tiempo": {
    "tipo": "dirigido",
    "modalidad": "encargo",
    "descripcion": "Se ejecuta a solicitud del usuario. Cada vez que se invoca bdgb --glifo-run generacion-contenido, recorre el pipeline completo una vez y termina"
  },

  "config": {
    "pipeline": ["estrutura", "trend-fetcher", "authority-selector", "content-writer", "clipboard-capturer", "guion-loader", "notebook-video", "youtube-publisher", "cleanup"]
  },

  "glifos": [
    {
      "id": "estrutura",
      "nombre": "Verificador de Estructura",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/estrutura/estrutura.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Verifica que todos los directorios, archivos y recursos necesarios existen. Crea los que faltan.",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/estrutura/glifo.json"
    },
    {
      "id": "trend-fetcher",
      "nombre": "Buscador de Tendencias",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/trend-fetcher/trend_fetcher.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Obtiene tendencias de internet (Google Trends RSS + pytrends)",
      "inputs": [],
      "outputs": ["pipeline_state/tendencias.json"],
      "glifo_json": "glifos/trend-fetcher/glifo.json"
    },
    {
      "id": "authority-selector",
      "nombre": "Selector por Autoridad",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/authority-selector/selector.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Recibe las tendencias y elige la de mayor autoridad (score + volumen)",
      "inputs": ["pipeline_state/tendencias.json"],
      "outputs": ["pipeline_state/tema_seleccionado.json"],
      "glifo_json": "glifos/authority-selector/glifo.json"
    },
    {
      "id": "content-writer",
      "nombre": "Redactor de Articulos IA",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/content-writer/writer.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Abre ChatGPT en navegador via CDP, escribe prompt natural, extrae respuesta",
      "inputs": ["pipeline_state/tema_seleccionado.json"],
      "outputs": ["pipeline_state/respuesta_ia.txt"],
      "glifo_json": "glifos/content-writer/glifo.json"
    },
    {
      "id": "clipboard-capturer",
      "nombre": "Capturador de Portapapeles",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/clipboard-capturer/capturer.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Lee respuesta_ia.txt y genera PDF en Desktop/guiones/",
      "inputs": ["pipeline_state/respuesta_ia.txt"],
      "outputs": ["Desktop/guiones/*.pdf"],
      "glifo_json": "glifos/clipboard-capturer/glifo.json"
    },
    {
      "id": "guion-loader",
      "nombre": "Cargador de Guion desde PDF",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/guion-loader/guion_loader.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Busca PDF mas reciente en ~/Desktop/guiones/, extrae texto a pipeline_state/guion.txt",
      "inputs": [],
      "outputs": ["pipeline_state/guion.txt", "pipeline_state/guion_meta.json"],
      "glifo_json": "glifos/guion-loader/glifo.json"
    },
    {
      "id": "notebook-video",
      "nombre": "Generador de Video via NotebookLM",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/notebook-video/notebook_video.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Abre NotebookLM en Chrome via CDP, crea cuaderno, adjunta guion, genera video, descarga",
      "inputs": ["pipeline_state/guion.txt"],
      "outputs": ["pipeline_state/video.mp4"],
      "glifo_json": "glifos/notebook-video/glifo.json"
    },
    {
      "id": "youtube-publisher",
      "nombre": "Publicador de Video en YouTube",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/youtube-publisher/youtube_publisher.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Abre YouTube Studio via CDP, sube video al canal glifos, publica",
      "inputs": ["pipeline_state/video.mp4", "pipeline_state/guion_meta.json"],
      "outputs": ["pipeline_state/publicado.json"],
      "glifo_json": "glifos/youtube-publisher/glifo.json"
    },
    {
      "id": "cleanup",
      "nombre": "Limpiador de Recursos",
      "tipo": "externo",
      "entry": "python3 glifos/generacion-contenido/glifos/cleanup/cleaner.py",
      "lenguaje": "python3",
      "actualizable": true,
      "descripcion": "Cierra Chrome/Edge lanzados por content-writer, notebook-video, youtube-publisher; libera puertos CDP; limpia pipeline_state/",
      "inputs": [],
      "outputs": [],
      "glifo_json": "glifos/cleanup/glifo.json"
    }
  ],

  "relaciones": [
    {
      "de": "trend-fetcher",
      "a": "authority-selector",
      "tipo": "datos",
      "flujo": "trend-fetcher escribe pipeline_state/tendencias.json, authority-selector lo lee",
      "protocolo": "pipeline_state/tendencias.json"
    },
    {
      "de": "authority-selector",
      "a": "content-writer",
      "tipo": "datos",
      "flujo": "authority-selector escribe pipeline_state/tema_seleccionado.json, content-writer lo lee",
      "protocolo": "pipeline_state/tema_seleccionado.json"
    },
    {
      "de": "content-writer",
      "a": "clipboard-capturer",
      "tipo": "archivo",
      "flujo": "content-writer escribe pipeline_state/respuesta_ia.txt, clipboard-capturer lo lee",
      "protocolo": "pipeline_state/respuesta_ia.txt"
    },
    {
      "de": "clipboard-capturer",
      "a": "guion-loader",
      "tipo": "archivo",
      "flujo": "clipboard-capturer genera PDF en ~/Desktop/guiones/, guion-loader lo lee y extrae texto",
      "protocolo": "~/Desktop/guiones/<ultimo>.pdf"
    },
    {
      "de": "guion-loader",
      "a": "notebook-video",
      "tipo": "datos",
      "flujo": "guion-loader escribe pipeline_state/guion.txt, notebook-video lo usa como fuente en NotebookLM",
      "protocolo": "pipeline_state/guion.txt"
    },
    {
      "de": "notebook-video",
      "a": "youtube-publisher",
      "tipo": "archivo",
      "flujo": "notebook-video descarga y copia video a pipeline_state/video.mp4, youtube-publisher lo sube",
      "protocolo": "pipeline_state/video.mp4"
    },
    {
      "de": "youtube-publisher",
      "a": "cleanup",
      "tipo": "cierre",
      "flujo": "cleanup cierra Chrome, libera puertos CDP, elimina pipeline_state/",
      "protocolo": "ninguno"
    }
  ],

  "pipeline": {
    "orden": [
      {
        "paso": 0,
        "glifo": "estrutura",
        "accion": "verify",
        "args": [],
        "descripcion": "Verificar estructura del panal: directorios, archivos, recursos. Crear lo faltante."
      },
      {
        "paso": 1,
        "glifo": "trend-fetcher",
        "accion": "fetch",
        "args": [],
        "dependencias": ["estrutura"],
        "descripcion": "Obtener tendencias de Google Trends RSS + pytrends, guardar en pipeline_state/tendencias.json"
      },
      {
        "paso": 2,
        "glifo": "authority-selector",
        "accion": "select",
        "args": [],
        "dependencias": ["trend-fetcher"],
        "descripcion": "Leer pipeline_state/tendencias.json, seleccionar la de mayor autoridad, guardar en pipeline_state/tema_seleccionado.json"
      },
      {
        "paso": 3,
        "glifo": "content-writer",
        "accion": "cdp-browser",
        "args": [],
        "dependencias": ["authority-selector"],
        "descripcion": "Abrir ChatGPT en Chrome via CDP, escribir prompt, enviar, extraer respuesta a pipeline_state/respuesta_ia.txt"
      },
      {
        "paso": 4,
        "glifo": "clipboard-capturer",
        "accion": "pdf",
        "args": [],
        "dependencias": ["content-writer"],
        "descripcion": "Leer pipeline_state/respuesta_ia.txt, generar PDF en Desktop/guiones/"
      },
      {
        "paso": 5,
        "glifo": "guion-loader",
        "accion": "extract",
        "args": [],
        "dependencias": ["clipboard-capturer"],
        "descripcion": "Leer PDF mas reciente de ~/Desktop/guiones/, extraer texto a pipeline_state/guion.txt"
      },
      {
        "paso": 6,
        "glifo": "notebook-video",
        "accion": "cdp-notebooklm",
        "args": [],
        "dependencias": ["guion-loader"],
        "descripcion": "Abrir NotebookLM en Chrome via CDP, crear cuaderno, adjuntar guion, generar video, descargar a pipeline_state/video.mp4"
      },
      {
        "paso": 7,
        "glifo": "youtube-publisher",
        "accion": "cdp-youtube",
        "args": [],
        "dependencias": ["notebook-video"],
        "descripcion": "Abrir YouTube Studio en Chrome via CDP, subir video al canal glifos, publicar"
      },
      {
        "paso": 8,
        "glifo": "cleanup",
        "accion": "clean",
        "args": [],
        "dependencias": ["youtube-publisher"],
        "descripcion": "Cerrar Chrome/Edge, liberar puertos CDP, limpiar pipeline_state/"
      }
    ]
  },

  "datos_panal": {
    "protocolo_comunicacion": "pipeline_state/ — archivos JSON/txt temporales. Cada glifo lee inputs de ahi y escribe outputs.",
    "fuentes": ["google-trends-rss", "pytrends-api", "mock-internet"],
    "criterio_autoridad": "score + volumen de busqueda",
    "formato_salida": "PDF → Video MP4 → YouTube",
    "carpeta_destino_guion": "Desktop/guiones/",
    "carpeta_destino_video": "~/Desktop/videos/",
    "canal_youtube": "glifos",
    "cdp_puertos": {
      "content-writer": 9222,
      "notebook-video": 9333,
      "youtube-publisher": 9444
    },
    "ia_modo": "navegador CDP (automatico via Chrome DevTools Protocol, o interactivo como fallback)",
    "ia_config": {
      "url_web": "https://chatgpt.com",
      "metodo": "CDP WebSocket → JavaScript → prompt → Enter → extraer respuesta",
      "dependencias": "websocket-client (pip install)",
      "variable_entorno_sitio": "BDGB_AI_WEB_URL",
      "variable_entorno_modo": "BDGB_AI_MODE (browser | mock)"
    }
  },

  "metricas": {
    "ejecuciones": 0,
    "exitosas": 0,
    "fallidas": 0,
    "ultima_ejecucion": null,
    "articulos_generados": 0,
    "videos_generados": 0,
    "videos_publicados": 0
  }
}
