{
  "id": "youtube-publisher",
  "nombre": "Publicador de Video en YouTube",
  "tipo": "externo",
  "glifo_principal": false,
  "descripcion": "Abre YouTube Studio en Chrome via CDP con sesion del usuario, sube video.mp4 de pipeline_state al canal 'glifos', llena titulo/descripcion y publica.",
  "entry": "python3 glifos/generacion-contenido/glifos/youtube-publisher/youtube_publisher.py",
  "actualizable": true,
  "lenguaje": "python3",
  "inputs": [
    {"archivo": "pipeline_state/video.mp4", "formato": "video/mp4", "descripcion": "Video generado por notebook-video"},
    {"archivo": "pipeline_state/guion_meta.json", "formato": "json", "descripcion": "Metadatos para titulo del video"}
  ],
  "outputs": [
    {"archivo": "pipeline_state/publicado.json", "formato": "json", "descripcion": "Confirmacion de publicacion con URL del video"}
  ],
  "dependencias": ["notebook-video"],
  "tiempo": {
    "modalidad": "dirigido",
    "inicio": {"trigger": "dependencia", "via": "pipeline_state/video.mp4"},
    "fin": {"tipo": "cleanup", "descripcion": "Video publicado en YouTube canal glifos"}
  },
  "bibliotecario": {
    "recursos": [],
    "credenciales": {
      "google": {"tipo": "env", "keys": [], "nota": "usa sesion guardada en chrome_data/"},
      "youtube_channel": {"tipo": "fijo", "value": "glifos"}
    },
    "permisos": ["read:pipeline_state", "read:~/Desktop/videos", "write:https://studio.youtube.com"]
  },
  "config": {
    "url": "https://studio.youtube.com",
    "canal": "glifos",
    "metodo": "CDP semi-automatico (usuario completa upload manualmente)",
    "puerto_cdp": 9444
  },
  "panal": "generacion-contenido",
  "version": "1.0"
}
