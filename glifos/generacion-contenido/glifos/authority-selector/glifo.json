{
  "id": "authority-selector",
  "nombre": "Selector por Autoridad",
  "tipo": "externo",
  "glifo_principal": false,
  "descripcion": "Recibe tendencias y elige la de mayor autoridad (score + categoria + longitud). Segundo paso del pipeline.",
  "entry": "python glifos/generacion-contenido/glifos/authority-selector/selector.py",
  "actualizable": true,
  "lenguaje": "python3",
  "inputs": [
    {"archivo": "pipeline_state/tendencias.json", "formato": "json", "descripcion": "Tendencias del trend-fetcher"}
  ],
  "outputs": [
    {"archivo": "pipeline_state/tema_seleccionado.json", "formato": "json", "descripcion": "Tendencia ganadora con score de autoridad"}
  ],
  "dependencias": ["trend-fetcher"],
  "tiempo": {
    "modalidad": "dirigido",
    "inicio": {"trigger": "dependencia", "via": "pipeline_state/tendencias.json"},
    "fin": {"tipo": "senal", "descripcion": "Escribe pipeline_state/tema_seleccionado.json"}
  },
  "bibliotecario": {
    "recursos": [],
    "credenciales": {},
    "permisos": ["read:pipeline_state", "write:pipeline_state"]
  },
  "config": {
    "criterio": "score + bonus_categoria + bonus_longitud",
    "bonus_categoria": {"tecnologia": 5, "ciencia": 5, "educacion": 3}
  },
  "panal": "generacion-contenido",
  "version": "2.0"
}
